{
  "name": "ayub-academic-os",
  "version": "1.0.0",
  "private": true,
  "description": "AYUB Academic OS - The Ultimate Student Academic & Career Operating System",
  "scripts": {
    "postinstall": "cd server && npm install && cd ../client && npm install",
    "dev": "concurrently -n SERVER,CLIENT -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npx tsx src/index.ts",
    "dev:client": "cd client && npx vite --host",
    "build": "concurrently \"npm run build:server\" \"npm run build:client\"",
    "build:server": "cd server && npx tsc",
    "build:client": "cd client && npx vite build",
    "setup": "cd server && npm install && npx prisma generate && npx prisma migrate dev --name init && cd ../client && npm install",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "cd server && node dist/index.js",
    "start:client": "cd client && npx vite preview --host"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "5.5"
  }
}
